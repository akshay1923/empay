# Postgres on the local machine — assumes default postgres/postgres user
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/empay?schema=public"

# Generate with: npx auth secret
AUTH_SECRET="replace-me-with-output-of-npx-auth-secret"
AUTH_TRUST_HOST=true

# Gmail SMTP for sending login credentials to new employees.
# Use a Google App Password (https://myaccount.google.com/apppasswords),
# NOT your normal Gmail password. 2FA must be on for the account.
SMTP_USER="hr@yourcompany.com"
SMTP_PASS="xxxxxxxxxxxxxxxx"
# Optional friendly From; defaults to "EmPay HR <SMTP_USER>"
SMTP_FROM="EmPay HR <hr@yourcompany.com>"

# Payroll column encryption (AES-256-GCM). Generate with:
#   openssl rand -base64 32
# Lose this key and every payslip and ctcAnnual on disk is unreadable —
# treat it like a database backup. See docs/payroll-encryption.md.
PAYROLL_ENCRYPTION_KEY="aiFm+izTVSND8yvxLL/DudBzfom+iDddlxJNqD7V6Sg="
